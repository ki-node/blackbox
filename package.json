{
  "name": "black-box",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "^22.13.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build && npm run budget",
    "build:embedded": "node scripts/build-embedded.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "eslint . --max-warnings=0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:ci": "playwright test",
    "test:embedded:e2e": "playwright test --config playwright.embedded.config.ts",
    "test:reproducible": "node scripts/check-reproducible.mjs",
    "check:embedded": "node scripts/check-embedded.mjs",
    "check": "npm run format:check && npm run lint && npm run test && npm run build",
    "check:all": "npm run check && npm run build:embedded && npm run check:embedded && npm run test:reproducible",
    "budget": "node scripts/check-bundle-size.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "stylelint": "^17.14.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
